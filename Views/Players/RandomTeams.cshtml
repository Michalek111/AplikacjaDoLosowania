@{
    ViewData["Title"] = "Wylosowane Drużyny";
    var team1 = ViewBag.Team1 as List<AplikacjaDoLosowania.Models.Player>;
    var team2 = ViewBag.Team2 as List<AplikacjaDoLosowania.Models.Player>;
}

<h2 class="text-center">Wylosowane Drużyny</h2>

<div class="container">
    <div class="row">
        <div class="col-md-5">
            <h4>🏆 Drużyna 1</h4>
            <ul class="list-group">
                @foreach (var player in team1)
                {
                    <li class="list-group-item">@player.Nick</li>
                }
            </ul>
        </div>
        <div class="col-md-5 offset-md-2">
            <h4>🔥 Drużyna 2</h4>
            <ul class="list-group">
                @foreach (var player in team2)
                {
                    <li class="list-group-item">@player.Nick</li>
                }
            </ul>
        </div>
    </div>
    <a asp-action="SelectPlayers" class="btn btn-secondary mt-3">🔄 Wybierz ponownie</a>
</div>
